# Network: "local" or "testnet"
NETWORK=local

# Local devnet
LOCAL_JSON_RPC_URL=http://localhost:8545
LOCAL_LCD_URL=http://localhost:1317

# Initia testnet
TESTNET_JSON_RPC_URL=https://jsonrpc-evm-1.anvil.asia-southeast.initia.xyz
TESTNET_LCD_URL=https://lcd.preyominet-1.initia.tech

# Backend wallet (same as contract deployer for onlyOwner)
PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# Contract (set after deployment)
CONTRACT_ADDRESS=0x_DEPLOYED_CONTRACT_ADDRESS

# Signal engine
SIGNAL_INTERVAL_MINUTES=5
SIGNAL_RESOLVE_TIMEOUT_HOURS=24

# MPP Payment Contracts (deployed by deploy.sh)
SESSION_VAULT_ADDRESS=
MOCK_IUSD_ADDRESS=
PAYMENT_GATEWAY_ADDRESS=
ENABLE_PAYMENT_GATING=true
FREE_SIGNALS_PER_DAY=3

# Stellar / Trustless Work (Signal Marketplace)
TRUSTLESS_API_URL=https://dev.api.trustlesswork.com
TRUSTLESS_API_KEY=
STELLAR_PLATFORM_ADDRESS=
STELLAR_FEE_ADDRESS=
STELLAR_ADMIN_ADDRESS=
STELLAR_NETWORK=testnet

# ─────────────────────────────────────────────────────────────────────────
# Note: x402 / paid-agent endpoints are now served by the Node service in
# `backend/agent-provider/`. Configure that service via its own .env file
# (see backend/agent-provider/.env.example). The Python service only serves
# unpaid /api/* on loopback after the Node cutover.
# ─────────────────────────────────────────────────────────────────────────

# ─────────────────────────────────────────────────────────────────────────
# Somnia x402 rail (Agentathon — chain 50312, REST mirror of SomniaAgentMarket)
# ─────────────────────────────────────────────────────────────────────────
# Set SOMNIA_X402_ENABLED=true after deploying contracts/script/05_DeploySomnia.s.sol
# and funding the receiver via the Somnia testnet faucet (https://testnet.somnia.network).
# Receiver falls back to X402_RECEIVER_ADDRESS if not set.
SOMNIA_X402_ENABLED=false
SOMNIA_X402_NETWORK=eip155:50312
SOMNIA_X402_FACILITATOR_URL=https://api.cdp.coinbase.com/platform/v2/x402
SOMNIA_X402_RECEIVER_ADDRESS=
SOMNIA_X402_PUBLIC_BASE_URL=

# Somnia deployed contract addresses (auto-populated by scripts/sync-deployments.mjs --chain 50312)
SOMNIA_SIGNAL_REGISTRY_ADDRESS=
SOMNIA_CONVICTION_ENGINE_ADDRESS=
SOMNIA_ORACLE_ADAPTER_ADDRESS=
SOMNIA_SIGNAL_AGENT_ADDRESS=
SOMNIA_SESSION_VAULT_ADDRESS=
SOMNIA_MOCK_STT_ADDRESS=
SOMNIA_CARD_EXECUTOR_ADDRESS=
SOMNIA_AGENT_MARKET_ADDRESS=

# ─────────────────────────────────────────────────────────────────────────
# Prophecy.social prediction-card mode
# ─────────────────────────────────────────────────────────────────────────
# Cross-chain split: read mainnet 5031, swipe + settle on testnet 50312.
# Day-0 verify contract addresses on https://browser.somnia.network and
# populate below. `PROPHECY_CARD_GEN_ENABLED=true` is the only flag the
# pipeline + scheduler check — leaving it false is the safe default.
SOMNIA_MAINNET_RPC=https://api.infra.mainnet.somnia.network
SOMNIA_TESTNET_RPC=https://api.infra.testnet.somnia.network
PROPHECY_MARKET_ADDRESS=
PROPHECY_PST_TOKEN_ADDRESS=
PROPHECY_API_BASE_URL=https://prophecy.social
PROPHECY_CACHE_TTL_SECONDS=900
PROPHECY_BRIDGE_ADDRESS=
PROPHECY_CARD_GEN_ENABLED=false

# ─────────────────────────────────────────────────────────────────────────
# GOAT testnet x402 rail (chain 48816, /goat-api/* prefix)
# ─────────────────────────────────────────────────────────────────────────
# Buyer-direct verify-only paywall (no facilitator dependency). Buyers
# transfer the configured ERC-20 (default WGBTC since USDC is not yet
# issued on goat-testnet3) on-chain, then retry the request with header
# `X-Payment-Tx: <hash>`. The seller verifies the receipt + Transfer log.
# Buyer reference flow: ../payment/agent-payment/scripts/x402-pay.mjs
GOAT_X402_ENABLED=false
GOAT_X402_CHAIN_ID=48816
GOAT_X402_NETWORK=eip155:48816
GOAT_X402_RPC_URL=https://rpc.testnet3.goat.network
GOAT_X402_RECEIVER_ADDRESS=
GOAT_X402_TOKEN_ADDRESS=0xbC10000000000000000000000000000000000000
GOAT_X402_TOKEN_SYMBOL=WGBTC
GOAT_X402_TOKEN_DECIMALS=18
GOAT_X402_TOKEN_USD_PRICE=65000.0
GOAT_X402_PUBLIC_BASE_URL=
