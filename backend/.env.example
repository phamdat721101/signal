# Network: "local" or "testnet"
NETWORK=local

# Local devnet
LOCAL_JSON_RPC_URL=http://localhost:8545
LOCAL_LCD_URL=http://localhost:1317

# Initia testnet
TESTNET_JSON_RPC_URL=https://jsonrpc-evm-1.anvil.asia-southeast.initia.xyz
TESTNET_LCD_URL=https://lcd.preyominet-1.initia.tech

# Backend wallet (same as contract deployer for onlyOwner)
PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# Contract (set after deployment)
CONTRACT_ADDRESS=0x_DEPLOYED_CONTRACT_ADDRESS

# Signal engine
SIGNAL_INTERVAL_MINUTES=5
SIGNAL_RESOLVE_TIMEOUT_HOURS=24

# MPP Payment Contracts (deployed by deploy.sh)
SESSION_VAULT_ADDRESS=
MOCK_IUSD_ADDRESS=
PAYMENT_GATEWAY_ADDRESS=
ENABLE_PAYMENT_GATING=true
FREE_SIGNALS_PER_DAY=3

# Stellar / Trustless Work (Signal Marketplace)
TRUSTLESS_API_URL=https://dev.api.trustlesswork.com
TRUSTLESS_API_KEY=
STELLAR_PLATFORM_ADDRESS=
STELLAR_FEE_ADDRESS=
STELLAR_ADMIN_ADDRESS=
STELLAR_NETWORK=testnet

# ─────────────────────────────────────────────────────────────────────────
# Morph Rails x402 (parallel agent payment rail — Hoodi testnet by default)
# ─────────────────────────────────────────────────────────────────────────
# Set MORPH_X402_ENABLED=true after creating Access/Secret keys at
# https://morph-rails.morph.network/x402 and funding the receiver via
# https://morph-rails-hoodi.morph.network/faucet.
MORPH_X402_ENABLED=false
MORPH_FACILITATOR_URL=https://morph-rails-hoodi.morph.network/x402
MORPH_NETWORK=eip155:2910
MORPH_RECEIVER_ADDRESS=
MORPH_ASSET_ADDRESS=0xEcF966Cc754BC411E1F1106fbb4e343b835E85E4
MORPH_ASSET_DECIMALS=18
MORPH_ASSET_NAME=HoodiTestToken
MORPH_ASSET_VERSION=1.0
MORPH_ACCESS_KEY=
MORPH_ACCESS_SECRET=
MORPH_PUBLIC_BASE_URL=

# ─────────────────────────────────────────────────────────────────────────
# Note: x402 / paid-agent endpoints are now served by the Node service in
# `backend/agent-provider/`. Configure that service via its own .env file
# (see backend/agent-provider/.env.example). The Python service only serves
# unpaid /api/* on loopback after the Node cutover.
# ─────────────────────────────────────────────────────────────────────────
