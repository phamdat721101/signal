{
  "name": "signal-agent-provider",
  "version": "0.2.0",
  "private": true,
  "description": "x402 payment gateway for Signal Trading Intelligence API on Arbitrum Sepolia (buyer-direct EIP-3009)",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/src/server.js",
    "dev": "tsx watch src/server.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "dotenv": "16.4.7",
    "express": "4.21.2",
    "n-payment": "0.18.0",
    "undici": "7.2.0",
    "viem": "2.21.55",
    "x402-fetch": "0.5.0",
    "zod": "3.24.1"
  },
  "devDependencies": {
    "@types/express": "4.17.21",
    "@types/node": "22.10.2",
    "tsx": "4.19.2",
    "typescript": "5.7.2"
  }
}
