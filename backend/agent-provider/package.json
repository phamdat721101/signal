{
  "name": "signal-agent-provider",
  "version": "0.1.0",
  "private": true,
  "description": "Multi-chain x402 payment gateway for Signal Trading Intelligence API",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "start:settler": "node dist/settler.js",
    "dev": "tsx watch src/server.ts",
    "smoke": "tsx scripts/smoke.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "migrate": "node scripts/migrate.mjs"
  },
  "dependencies": {
    "dotenv": "16.4.7",
    "express": "4.21.2",
    "n-payment": "0.12.0",
    "pg": "8.13.1",
    "undici": "7.2.0",
    "zod": "3.24.1"
  },
  "devDependencies": {
    "@types/express": "4.17.21",
    "@types/node": "22.10.2",
    "@types/pg": "8.11.10",
    "tsx": "4.19.2",
    "typescript": "5.7.2"
  }
}
