# Service
PORT=8002
NODE_ENV=production
LOG_LEVEL=info
PUBLIC_BASE_URL=https://ai.overguild.com/agent-api

# Internal Python data layer (loopback only)
PYTHON_INTERNAL_URL=http://127.0.0.1:8001

# Postgres (reuses Signal's DB; must be reachable from Node)
DATABASE_URL=postgres://signal:signal@127.0.0.1:5432/signal

# ──────────────────────────────────────────────────────────────────────
# x402 payment rail — Arbitrum Sepolia testnet (standard `exact` scheme)
# USDC: 0x75faf114eafb1BDbe2F0316DF893fd58CE46AA4d (Circle, Arb Sepolia)
# Buyer pays gas (~$0.0001 testnet ETH) — no sponsor wallet, no local
# facilitator process. Facilitator default = public x402.org service.
# ──────────────────────────────────────────────────────────────────────
PAY_TO_ADDRESS=0xYourArbitrumSepoliaReceiver
FACILITATOR_URL=https://x402.org/facilitator
