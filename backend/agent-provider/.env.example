# Service
PORT=8002
NODE_ENV=production
LOG_LEVEL=info
PUBLIC_BASE_URL=https://ai.overguild.com/agent-api

# Internal Python data layer (loopback only)
PYTHON_INTERNAL_URL=http://127.0.0.1:8001

# Postgres (reuses Signal's DB; must be reachable from Node)
DATABASE_URL=postgres://signal:signal@127.0.0.1:5432/signal

# Mainnet receivers (REQUIRED for Base; OPTIONAL for Stellar/Tempo)
BASE_RECEIVER=0xYourBaseReceiver
STELLAR_RECEIVER=GYourStellarReceiver
TEMPO_RECEIVER=0xYourTempoReceiver

# CDP facilitator credentials (REQUIRED for Base mainnet verify+settle)
CDP_API_KEY_ID=
CDP_API_KEY_SECRET=

# OpenZeppelin Channels facilitator API key (REQUIRED for Stellar mainnet)
OZ_API_KEY=

# Service-side Stellar wallet secret for settle proofs (OPTIONAL on testnet)
STELLAR_SECRET=
