# Network: "local" or "testnet"
VITE_NETWORK=local

# EVM JSON-RPC (viem contract reads)
VITE_LOCAL_JSON_RPC_URL=http://localhost:8545
VITE_TESTNET_JSON_RPC_URL=https://jsonrpc-evm-1.anvil.asia-southeast.initia.xyz

# Cosmos endpoints (InterwovenKit)
VITE_COSMOS_RPC_URL=http://localhost:26657
VITE_REST_URL=http://localhost:1317

# Appchain identity (from weave init)
VITE_CHAIN_ID=minitia-1
VITE_NATIVE_DENOM=umin
VITE_NATIVE_SYMBOL=MIN

# Contract (set after deployment)
VITE_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000

# Backend API
VITE_BACKEND_URL=http://localhost:8000

# Demo mode
VITE_DEMO_MODE=false
